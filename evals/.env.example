# Copy this to the REPO ROOT as `.env.local` (already gitignored via `.env.*`) and fill in
# your key. The eval runner loads it from the repo root; the key is never committed, never
# printed, and only ever sent to OpenAI.
#
#   cp evals/.env.example .env.local   # then edit .env.local
#
OPENAI_API_KEY=sk-your-key-here

# Optional: if you later add Claude models to the matrix (promptfoo `anthropic:` provider).
# ANTHROPIC_API_KEY=
